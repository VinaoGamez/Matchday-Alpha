{
  "name": "matchday-football-alpha",
  "version": "0.2.0-alpha",
  "private": true,
  "description": "Matchday Football — simulador de gestão (Alpha 02 modular)",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test:match-view": "node scripts/match-view-play-tests.mjs",
    "test:world-pitch": "node scripts/match-view-world-tests.mjs",
    "test:match-view-all": "npm run test:world-pitch && npm run test:match-view",
    "test:all": "node scripts/run-all-tests.mjs",
    "test:ao-vivo-2d": "node modules/ao-vivo-2d/scripts/run-tests.mjs lab",
    "test:ao-vivo-2d:frozen": "node modules/ao-vivo-2d/scripts/run-tests.mjs frozen",
    "test:knockout-shootout": "node scripts/knockout-shootout-tests.mjs",
    "test:season-goal-live": "node scripts/season-goal-live-tests.mjs",
    "test:player-history": "node scripts/player-history-tests.mjs",
    "test:own-goal-report": "node scripts/own-goal-report-tests.mjs",
    "deploy:testers": "npm run build && npx wrangler pages deploy dist --project-name matchday-football-alpha --branch main"
  },
  "devDependencies": {
    "vite": "^6.3.5"
  }
}
